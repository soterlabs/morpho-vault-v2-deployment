RPC_URL=https://eth.llamarpc.com
PRIVATE_KEY=0x...
# Safe 1/3 multisig address (must be set as allocator on the vault)
SAFE_ADDRESS=0x...
VAULT_ADDRESS=
ADAPTER_ADDRESS=
ORACLE_STUSDS=0x0A976226d113B67Bd42D672Ac9f83f92B44b454C
ORACLE_CBBTC=0x...
ORACLE_WSTETH=0x...
ORACLE_WETH=0x...
LLTV_STUSDS=860000000000000000
LLTV_CBBTC=860000000000000000
LLTV_WSTETH=860000000000000000
LLTV_WETH=860000000000000000
# Per-market allocation targets in basis points (10000 = 100%).
# Defaults to 500 (5%) each when unset. The sum across ALL FOUR markets (including any
# without an oracle, which still default to 500) must equal the bot's
# targetAllocatedPercent (2000 = 20%) — the bot throws on startup otherwise.
# For the stUSDS+WETH deallocation migration, set:
#   TARGET_STUSDS_BPS=0
#   TARGET_CBBTC_BPS=1000
#   TARGET_WSTETH_BPS=1000
#   TARGET_WETH_BPS=0
# IMPORTANT: every market that is grown OR drained must have its ORACLE_* set above.
# A market with no oracle (0x0) is ignored entirely — it is never allocated to, and if
# it still holds funds it can never be drained, so the migration would silently stall.
# In particular this migration requires ORACLE_CBBTC, ORACLE_WSTETH, and ORACLE_WETH
# (WETH must be set even though its target is 0, so its existing ~5% can be deallocated).
TARGET_STUSDS_BPS=500
TARGET_CBBTC_BPS=500
TARGET_WSTETH_BPS=500
TARGET_WETH_BPS=500
# Optional: cap how much (in USDS) the bot deallocates from each market per 6h cycle, for a
# gentler/gradual migration. Unset or 0 means no extra cap (limited only by target and the
# pool's available liquidity). Allocations are always bounded by the vault's 20% adapter cap.
MAX_DEALLOCATE_USDS=0
DRY_RUN=false
